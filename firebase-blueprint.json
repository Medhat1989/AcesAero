{
  "entities": {
    "Application": {
      "title": "Application",
      "description": "Talent application for aviation roles",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "Full name of the applicant" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "phone": { "type": "string", "description": "Phone number" },
        "role": { "type": "string", "description": "Desired role" },
        "experience": { "type": "string", "description": "Years of experience" },
        "message": { "type": "string", "description": "Cover letter or message" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "interviewed", "rejected"], "description": "Application status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission timestamp" }
      },
      "required": ["fullName", "email", "role", "createdAt"]
    },
    "Partnership": {
      "title": "Partnership",
      "description": "Business partnership request",
      "type": "object",
      "properties": {
        "companyName": { "type": "string", "description": "Name of the company" },
        "contactName": { "type": "string", "description": "Contact person name" },
        "email": { "type": "string", "format": "email", "description": "Business email" },
        "serviceType": { "type": "string", "description": "Type of service requested" },
        "message": { "type": "string", "description": "Partnership details" },
        "status": { "type": "string", "enum": ["new", "contacted", "active", "closed"], "description": "Request status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission timestamp" }
      },
      "required": ["companyName", "contactName", "email", "createdAt"]
    }
  },
  "firestore": {
    "/applications/{applicationId}": {
      "schema": "Application",
      "description": "Collection of talent applications"
    },
    "/partnerships/{partnershipId}": {
      "schema": "Partnership",
      "description": "Collection of partnership requests"
    }
  }
}
